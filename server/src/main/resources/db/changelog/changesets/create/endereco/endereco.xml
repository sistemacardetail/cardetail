<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-table-endereco" author="elielson.silva">
        <createTable tableName="endereco">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cep" type="varchar(8)"/>
            <column name="logradouro" type="varchar(200)"/>
            <column name="numero" type="varchar(20)"/>
            <column name="complemento" type="varchar(1000)"/>
            <column name="bairro" type="varchar(100)"/>
            <column name="id_cidade" type="UUID">
                <constraints foreignKeyName="fk_empresa_cidade" references="cidade(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
