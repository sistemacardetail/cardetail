<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-perfil-permissao" author="elielson.silva">
        <createTable tableName="perfil_permissao">
            <column name="id_perfil" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="id_permissao" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="perfil_permissao"
                       columnNames="id_perfil, id_permissao"
                       constraintName="pk_perfil_permissao"/>

        <addForeignKeyConstraint baseTableName="perfil_permissao"
                                 baseColumnNames="id_perfil"
                                 constraintName="fk_perfil_permissao_perfil"
                                 referencedTableName="perfil"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="perfil_permissao"
                                 baseColumnNames="id_permissao"
                                 constraintName="fk_perfil_permissao_permissao"
                                 referencedTableName="permissao"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
