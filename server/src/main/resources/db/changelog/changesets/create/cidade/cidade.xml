<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-table-cidade" author="elielson.silva">
        <createTable tableName="cidade">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="codigo_ibge" type="varchar(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="id_uf" type="UUID">
                <constraints foreignKeyName="fk_cidade_uf" references="uf(id)"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="cidade"
                columnNames="nome,id_uf"
                constraintName="uk_cidade_nome_uf"/>
    </changeSet>

</databaseChangeLog>
