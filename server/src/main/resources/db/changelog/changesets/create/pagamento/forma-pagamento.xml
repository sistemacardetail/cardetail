<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="create-table-forma-pagamento" author="elielson.silva">
        <preConditions onFail="MARK_RAN" onFailMessage="Tabela forma_pagamento já existe, pulando criação.">
            <not>
                <tableExists tableName="forma_pagamento"/>
            </not>
        </preConditions>

        <createTable tableName="forma_pagamento">
            <column name="id" type="numeric">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="descricao" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
