    <changeSet id="insert-cor-veiculo-branco" author="elielson.silva">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(1)
                FROM cor_veiculo
                WHERE REPLACE(UPPER(nome), ' ', '') = 'BRANCO'
            </sqlCheck>
        </preConditions>
        <insert tableName="cor_veiculo">
            <column name="nome" value="Branco"/>
        </insert>
    </changeSet>

