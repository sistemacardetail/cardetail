    <changeSet id="insert-perfil-permissoes" author="elielson.silva">
        <!-- ADMINISTRADOR - Todas as permissões -->
        <sql>
            INSERT INTO perfil_permissao (id_perfil, id_permissao)
            SELECT 1, id FROM permissao;
        </sql>

        <!-- FUNCIONARIO - Visualizar e criar/editar operações -->
        <sql>
            INSERT INTO perfil_permissao (id_perfil, id_permissao)
            SELECT 2, id
            FROM permissao
            WHERE codigo IN (
                'CLIENTES_VISUALIZAR', 'CLIENTES_CRIAR', 'CLIENTES_EDITAR',
                'AGENDAMENTOS_VISUALIZAR', 'AGENDAMENTOS_CRIAR', 'AGENDAMENTOS_EDITAR',
                'ORCAMENTOS_VISUALIZAR', 'ORCAMENTOS_CRIAR', 'ORCAMENTOS_EDITAR',
                'SERVICOS_VISUALIZAR',
                'PACOTES_VISUALIZAR',
                'CADASTROS_VISUALIZAR',
                'EMPRESA_VISUALIZAR'
            );
        </sql>
    </changeSet>

