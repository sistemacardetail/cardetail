<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="insert-unidade-produto-ml" author="elielson.silva">
        <preConditions onFail="MARK_RAN" onFailMessage="Unidade Produto 'ml' já existe.">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM unidade_produto WHERE UPPER(nome) = 'ML'
            </sqlCheck>
        </preConditions>

        <insert tableName="unidade_produto">
            <column name="nome" value="Ml"/>
            <column name="descricao" value="Mililitro"/>
        </insert>
    </changeSet>

