    <changeSet id="insert-marca-veiculo-chevrolet" author="elielson.silva">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM marca_veiculo WHERE UPPER(nome) = 'CHEVROLET'
            </sqlCheck>
        </preConditions>
        <insert tableName="marca_veiculo">
            <column name="nome" value="Chevrolet"/>
        </insert>
    </changeSet>

