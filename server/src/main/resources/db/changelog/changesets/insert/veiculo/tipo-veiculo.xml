<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="insert-tipo-veiculo-carro" author="elielson.silva">
        <preConditions onFail="MARK_RAN" onFailMessage="Tipo veículo 'Carro' já existe.">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM tipo_veiculo WHERE UPPER(descricao) = 'CARRO'
            </sqlCheck>
        </preConditions>

        <insert tableName="tipo_veiculo">
            <column name="descricao" value="Carro"/>
        </insert>
    </changeSet>

