# =============================================================
# CarDetail — Variáveis de Ambiente (template sem valores reais)
# Copie este arquivo para .env e preencha os valores na VPS.
# NUNCA commite o arquivo .env no repositório.
# =============================================================

# Banco de dados PostgreSQL
POSTGRES_DB=cardetail
POSTGRES_USER=seu_usuario_db
POSTGRES_PASSWORD=senha_forte_aqui

# JWT — gere com: openssl rand -base64 64
JWT_SECRET=gere_um_secret_forte_aqui
